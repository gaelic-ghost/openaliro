index 6267d8c..b541ebe 100644
--- a/applications/matter-aliro-door-lock-app/src/aliro/Kconfig
+++ b/applications/matter-aliro-door-lock-app/src/aliro/Kconfig
@@ -62,6 +62,24 @@ config DOOR_LOCK_TIME_CONCEPT
 	help
 	  If enabled, the Time concept is supported.
 
+config DOOR_LOCK_TIME_CONCEPT_RATCHET
+	bool "Ratchet system time forward from a verified Access Document"
+	default y
+	depends on DOOR_LOCK_TIME_CONCEPT
+	help
+	  Access Documents are minted on demand with validFrom set to the user
+	  device's current time (validUntil is effectively unbounded), so the
+	  validity check degenerates into "reader clock must not be behind the
+	  phone". The reader wall clock lives in RAM and the commissioner sets
+	  it exactly once, so after any reboot the reader falls back to stale
+	  Last Known Good Time and every step-up fails as not-yet-valid.
+	  If enabled, a document whose signature has already been verified and
+	  whose validFrom lies ahead of the reader clock ratchets the system
+	  time forward to validFrom (never backward) instead of failing.
+	  Trade-off: a credential issuer that signs a future-dated document can
+	  advance the reader clock early, weakening not-before enforcement and
+	  shifting schedule evaluation for time-bounded credentials.
+
 endmenu # Aliro features
 
 rsource "platform/Kconfig"
